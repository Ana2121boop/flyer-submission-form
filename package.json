{
  "name": "flyer-submission-form",
  "private": true,
  "version": "2.0.0",
  "main": "apps/api/src/server.ts",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev --workspace=@flyer/api",
    "build": "npm run build --workspaces --if-present",
    "start": "npm start --workspace=@flyer/api",
    "db:generate": "npm run generate --workspace=@flyer/db",
    "db:push": "npm run push --workspace=@flyer/db",
    "db:studio": "npm run studio --workspace=@flyer/db"
  },
  "engines": {
    "node": ">=20"
  }
}
